<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004" author="nesik">
        <createTable tableName="inspector_floors">
            <column name="inspector_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_inspector_floors_user"
                             references="users(id)"/>
            </column>
            <column name="floor_number" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey
                tableName="inspector_floors"
                columnNames="inspector_id, floor_number"
                constraintName="pk_inspector_floors"/>
    </changeSet>

</databaseChangeLog>
